# Files excluded from the wp.org build. /vendor is excluded: it holds only the
# Composer autoloader (self-contained plugin, no runtime deps) and autoload.php
# has an identical PSR-4 fallback, so vendor/ is not shipped.
/.git
/vendor
/.github
/.gitignore
/.distignore
/.wp-env.json
/.wp-env.override.json
/node_modules
/tests
/scripts
/docs
/composer.json
/composer.lock
/package.json
/package-lock.json
/phpcs.xml.dist
/phpstan.neon.dist
/phpstan-baseline.neon
/playwright.config.ts
/tsconfig.json
/vite.config.ts
/README.md
/SPEC.md
/.DS_Store

.DS_Store
/.wordpress-org
/test-results
/playwright-report
/.playwright-mcp
